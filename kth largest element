import heapq
class Solution:
    def findKthLargest(self, nums: List[int], k: int) -> int:
        n = len(nums)
        heap = []
        for ind in range(0,k):
            heapq.heappush(heap,nums[ind])
        for p in range(k,n):
            if(nums[p]>heap[0]):
               heapq.heappop(heap)
               heapq.heappush(heap,nums[p])
        return heap[0]
