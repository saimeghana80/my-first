'''
Definition for Node
class Node:
    def __init__(self, val):
        self.data = val
        self.left = None
        self.right = None
'''

class Solution:
    def findMaxFork(self, root, k):
        #code here
        ans = -1
        while(root is not None):
            if(root.data <= k):
                ans = root.data
                root = root.right
            else:
                root = root.left
        return ans
